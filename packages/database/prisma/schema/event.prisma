enum EventStatus {
	DRAFT
	ACTIVE
	CANCELLED
	FINISHED
}

enum EventVisibility {
	PUBLIC
	NEIGHBORHOOD
	PRIVATE
}

enum ParticipantRole {
	HOST
	MEMBER
}

enum ParticipantStatus {
	JOINED
	WAITLIST
	LEFT
}

model Event {
	id           String             @id @default(uuid())
	creatorId    String
	communityId  String?
	title        String
	description  String?
	startsAt     DateTime
	endsAt       DateTime?
	status       EventStatus        @default(ACTIVE)
	visibility   EventVisibility    @default(NEIGHBORHOOD)
	capacity     Int?
	lat          Decimal            @db.Decimal(9, 6)
	lng          Decimal            @db.Decimal(9, 6)
	addressText  String?
	createdAt    DateTime           @default(now())
	updatedAt    DateTime           @updatedAt
	creator      User               @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
	community    Community?         @relation(fields: [communityId], references: [id], onDelete: SetNull)
	participants EventParticipant[]
	eventTags    EventTag[]
	reports      Report[]
	chatMessages EventChatMessage[]
	reviews      EventReview[]
	checkIns     EventCheckIn[]

	@@index([startsAt, status])
	@@index([lat, lng])
	@@index([creatorId])
	@@index([communityId, startsAt])
}

model EventParticipant {
	eventId   String
	userId    String
	role      ParticipantRole   @default(MEMBER)
	status    ParticipantStatus @default(JOINED)
	joinedAt  DateTime          @default(now())
	event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
	user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@id([eventId, userId])
	@@index([userId])
	@@index([eventId, status])
}

enum NotificationType {
  EVENT_JOIN_REQUEST
  EVENT_JOIN_APPROVED
  EVENT_JOIN_REJECTED
  EVENT_CHECKIN
  SYSTEM
}

enum EventCheckInMethod {
  GEO
  QR
  CODE
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  meta      Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model EventChatMessage {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  message   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([userId, createdAt])
}

model EventReview {
  id           String   @id @default(uuid())
  eventId      String
  authorUserId String
  rating       Int
  text         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author       User     @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, authorUserId])
  @@index([eventId, createdAt])
}

model EventCheckIn {
  id        String             @id @default(uuid())
  eventId   String
  userId    String
  method    EventCheckInMethod
  code      String?
  createdAt DateTime           @default(now())
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, createdAt])
}
